{
  "name": "crofai-opencode-plugin",
  "version": "1.1.0",
  "description": "OpenCode plugin for CrofAI model loading and usage tracking",
  "type": "module",
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "crofai",
    "plugin",
    "ai",
    "llm",
    "reasoning",
    "deepseek",
    "openai-compatible"
  ],
  "author": "squispeb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/squispeb/crofai-opencode-plugin.git"
  },
  "homepage": "https://github.com/squispeb/crofai-opencode-plugin#readme",
  "bugs": {
    "url": "https://github.com/squispeb/crofai-opencode-plugin/issues"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.3",
    "tsdown": "^0.22.2",
    "typescript": "^5.0.0"
  }
}
